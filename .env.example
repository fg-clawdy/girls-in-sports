# Girls In Sports (GIS) — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Database ──
DATABASE_URL="postgresql://username:password@localhost:5432/girlsinsports"

# ── Redis (BullMQ job queue) ──
REDIS_URL="redis://localhost:6379"

# ── Static Auth (MVP) ──
AUTH_USERNAME="admin"
AUTH_PASSWORD="change-me-to-a-strong-password"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
AUTH_SECURE="false"

# ── AI/LLM Provider (Venice.ai) ──
VENICE_API_KEY="your-venice-api-key-here"
VENICE_API_URL="https://api.venice.ai/api/v1"

# ── Media Storage (Immich) ──
IMMICH_API_URL="http://localhost:2283"
IMMICH_API_KEY="your-immich-api-key-here"

# ── Production Admin Auth & Governance (US-001) ──
# High-entropy secret used for all admin operations (scripts + UI admin login).
# Distinct from AUTH_USERNAME/PASSWORD. Rotate periodically. Min 16 chars.
ADMIN_TOKEN="change-me-to-a-long-random-admin-token-at-least-32-chars"

# Optional comma-separated IPs or CIDRs allowed for admin in production.
# Localhost always permitted in dev. Example: "127.0.0.1,10.0.0.0/8,192.168.1.50"
ADMIN_IP_ALLOWLIST="127.0.0.1,::1"

# Set to "true" in production (forces Secure flag on gis-admin-session cookie)
ADMIN_COOKIE_SECURE="false"

# DB-backed rate limiting (applied to every /api/* request)
RATE_LIMIT_TOKENS=60
RATE_LIMIT_WINDOW_MS=60000
DEFAULT_EVENT_BUDGET_USD=5
DAILY_SPEND_ALERT_USD=20
WEEKLY_SPEND_ALERT_USD=100
FEEDBACK_ANALYSIS_THRESHOLD=5

# Weekly cleanup of expired rate limit buckets is handled by worker or a script.
