# Girls In Sports (GIS) — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Database ──
DATABASE_URL="postgresql://username:password@localhost:5432/girlsinsports"

# ── Static Auth (MVP) ──
AUTH_USERNAME="admin"
AUTH_PASSWORD="change-me-to-a-strong-password"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
AUTH_SECURE="false"

# ── AI/LLM Provider (Venice.ai) ──
VENICE_API_KEY="your-venice-api-key-here"
VENICE_API_URL="https://api.venice.ai/api/v1"

# ── Media Storage (Immich) ──
IMMICH_API_URL="http://localhost:2283"
IMMICH_API_KEY="your-immich-api-key-here"
