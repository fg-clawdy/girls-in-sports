# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit real secrets)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── GIS-specific runtime outputs ──
# Generated thumbnails, composition outputs, temp files
/public/thumbnails/*
/tmp/gis-compositions/
/tmp/gis-uploads/
*.mp4
*.mov
*.png
*.jpg
*.jpeg

# Exception: PWA icons must be committed
!/public/icon-192.png
!/public/icon-512.png

skills/
opencode.json