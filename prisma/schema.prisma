generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id              String           @id @default(cuid())
  name            String
  sport           String
  city            String
  eventDate       DateTime
  description     String?
  immichAlbumId   String?
  thumbnailUrl    String?
  userId          String?
  status          EventStatus      @default(READY)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  qualityTier     QualityTier      @default(PROFESSIONAL)
  costBudgetUSD       Float?
  currentEstimatedCost Float? @default(0)
  assets          Asset[]
  campaigns       Campaign[]
  feedbackRatings FeedbackRating[]
  generatedAssets GeneratedAsset[]

  @@map("events")
}

model Asset {
  id              String         @id @default(cuid())
  eventId         String
  immichAssetId   String?
  type            AssetType
  parentAssetId   String?
  filePath        String?
  durationSeconds Float?
  startTimeMs     Int?
  endTimeMs       Int?
  widthPx         Int?
  heightPx        Int?
  fps             Float?
  codec           String?
  sizeBytes       Int?
  status          AssetStatus    @default(UPLOADED)
  ingestJobId     String?
  motionLevel     String?        // 'LOW' | 'MEDIUM' | 'HIGH' — set during ingest segmentation
  dominantMode    String?        // 'ACTION' | 'SPEECH' | 'MIXED' — set during ingest segmentation
  transcriptWordsJson Json?      // Array of {word, startMs, endMs, speakerLabel?} scoped to this clip's time window
  createdAt       DateTime       @default(now())
  assetTags       AssetTag[]
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentAsset     Asset?         @relation("AssetParent", fields: [parentAssetId], references: [id])
  childAssets     Asset[]        @relation("AssetParent")
  campaignClips   CampaignClip[]
  clipScore       ClipScore?

  @@index([eventId])
  @@index([immichAssetId])
  @@index([parentAssetId])
  @@map("assets")
}

model ClipScore {
  id                String    @id @default(cuid())
  assetId           String    @unique
  visionScore       Float?
  audioScore        Float?
  motionScore       Float?
  compositeScore    Float?
  clipType          ClipType?
  hasFaces          Boolean   @default(false)
  hasCoachSpeech    Boolean   @default(false)
  hasActionKeyword  Boolean   @default(false)
  hasCrowdRoar      Boolean   @default(false)     // S1-05: detected via audio energy peaks
  audioSignalRescue Boolean   @default(false)     // S1-05: low-motion clip rescued by high audio signal
  transcriptExcerpt String?
  keywordHits       Json?
  transcriptionProvider String? // "venice-beta" | "whisper-fallback" | null
  speakerSegmentsJson   Json?     // Array of {speakerLabel, start, end, text}
  interestingnessJson   Json?     @map("interestingness_json")  // S1-06: array of {windowIndex,startTime,endTime,interestingnessScore,description,hasAction,hasEmotion,hasPeakMoment}
  quoteScoresJson       Json?     @map("quote_scores_json")      // S1-06: array of {text,startTime,endTime,speakerLabel,quoteQualityScore,reason}
  scoredAt          DateTime  @default(now())
  amateurScore      Float?    @map("amateurscore")
  intermediateScore Float?    @map("intermediatescore")
  professionalScore Float?    @map("professionalscore")
  momentScore       Float?    @map("momentscore")
  productionScore   Float?    @map("productionscore")
  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("clip_scores")
}

model AssetTag {
  id         String         @id @default(cuid())
  assetId    String
  tag        String
  source     AssetTagSource @default(GIS_AI)
  confidence Float?
  createdAt  DateTime       @default(now())
  asset      Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, tag])
  @@index([assetId])
  @@index([tag])
  @@map("asset_tags")
}

model Campaign {
  id                      String                   @id @default(cuid())
  eventId                 String
  userId                  String?
  name                    String
  targetFormat            TargetFormat
  energyPreset            EnergyPreset             @default(HYPE)
  brief                   String?
  status                  CampaignStatus           @default(DIRECTING)
  scriptJson              Json?
  musicUrl                String?
  musicPrompt             String?
  musicModelPreference    String?                   // S1-06: user-selectable music model (e.g. "elevenlabs-music", "ace-step", "auto")
  beatTimestampsJson      Json?                    // beat timestamps for music (for beat-sync cuts in render)
  proxyAssetId            String?
  finalAssetId            String?
  selectedAssetIds        String[]
  userFeedbackJson        Json?
  createdAt               DateTime                 @default(now())
  campaignClips           CampaignClip[]
  campaignFeedbacks       CampaignFeedback[]
  event                   Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  feedbackAnalysisReports FeedbackAnalysisReport[]

  @@index([eventId])
  @@index([status])
  @@map("campaigns")
}

model CampaignFeedback {
  id               String   @id @default(cuid())
  campaignId       String
  productionWorthy Boolean
  overallRating    Int
  wouldChange      String?
  clipSentiments   Json?
  musicSatisfied   Boolean?
  createdAt        DateTime @default(now())
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt])
  @@map("campaign_feedbacks")
}

model FeedbackAnalysisReport {
  id              String    @id @default(cuid())
  campaignId      String?
  generatedAt     DateTime  @default(now())
  reportJson      Json
  recommendations String
  appliedAt       DateTime?
  feedbackCount   Int       @default(0)
  campaign        Campaign? @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([generatedAt])
  @@map("feedback_analysis_reports")
}

model CampaignClip {
  id                 String   @id @default(cuid())
  campaignId         String
  assetId            String
  order              Int
  startTimeMs        Int?
  endTimeMs          Int?
  narrativeLabel     String?
  durationMultiplier Float    @default(1.0)
  accepted           Boolean  @default(true)
  mustInclude        Boolean  @default(false)
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  campaign           Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([assetId])
  @@map("campaign_clips")
}

model GeneratedAsset {
  id                   String                @id @default(cuid())
  eventId              String
  outputType           OutputType
  fileName             String
  filePath             String
  fileSize             Int                   @default(0)
  immichAssetId        String?
  compositionScript    String?
  costDIEM             Float?
  status               GenerationStatus      @default(PENDING)
  errorMessage         String?
  createdAt            DateTime              @default(now())
  completedAt          DateTime?
  compositionFeedbacks CompositionFeedback[]
  feedbackRatings      FeedbackRating[]
  event                Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("generated_assets")
}

// DEPRECATED (US-008): Legacy scene storage. All new scenes use child Asset(type=CLIP) with parentAssetId + startTimeMs/endTimeMs.
// Migration script converts old records. SceneSegment path and this model will be removed after migration + US-010.
model SceneSegment {
  id          String   @id @default(cuid())
  parentId    String
  eventId     String
  startTime   Float
  endTime     Float
  duration    Float
  motionScore Float
  createdAt   DateTime @default(now())

  @@index([parentId])
  @@index([eventId])
  @@map("scene_segments")
}

model CompositionFeedback {
  id                   String         @id @default(cuid())
  compositionId        String
  productionWorthy     Boolean
  ratings              Json?
  userIntent           String?
  generatedScript      Json?
  musicPrompt          String?
  musicModel           String?
  selectedAssetIds     String[]
  outputDuration       Float?
  freeformNotes        String?
  likedMost            String?
  wouldChange          String?
  estimatedImpressions Int?
  costDIEM             Float?
  createdAt            DateTime       @default(now())
  generatedAsset       GeneratedAsset @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@index([compositionId])
  @@index([createdAt])
  @@map("composition_feedbacks")
}

model FeedbackRating {
  id               String          @id @default(cuid())
  eventId          String
  sourceAssetId    String
  generatedAssetId String?
  rating           RatingType
  createdAt        DateTime        @default(now())
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  generatedAsset   GeneratedAsset? @relation(fields: [generatedAssetId], references: [id])

  @@map("feedback_ratings")
}

model AssetQualityFlag {
  id         String   @id @default(cuid())
  assetId    String
  eventId    String
  flags      String[]
  brightness Float?
  fileSize   Int
  duration   Float?
  createdAt  DateTime @default(now())

  @@index([eventId])
  @@index([assetId])
  @@map("asset_quality_flags")
}

model WeeklyCritique {
  id                  String   @id @default(cuid())
  weekStart           DateTime
  weekEnd             DateTime
  totalFeedback       Int
  avgProductionWorthy Float?
  avgRatings          Json?
  topIssues           String[]
  topLiked            String[]
  topChanges          String[]
  critiqueText        String
  actionItems         String[]
  suggestedChanges    Json?
  modelUsed           String
  costDIEM            Float?
  createdAt           DateTime @default(now())

  @@index([weekStart])
  @@map("weekly_critiques")
}

model Job {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(QUEUED)
  payload     Json?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error         String?
  qualityFlags  Json?     // structured partial-failure details (e.g. visionFailed:3, sttFailed:1, fallbacksUsed:true)
  retryAfter    DateTime?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  parentJobId   String?
  parentJob   Job?      @relation("JobParent", fields: [parentJobId], references: [id])
  childJobs   Job[]     @relation("JobParent")

  @@index([status])
  @@index([status, retryAfter])
  @@index([parentJobId])
  @@map("jobs")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // "ip:192.168.1.1" or "user:abc123" or "path:/api/admin/..."
  tokens    Int      @default(60)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@map("rate_limits")
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  actor         String // "admin" or partial hash of token for correlation
  action        String // e.g. "triggered-feedback-analysis", "increased-budget"
  route         String // "/api/admin/feedback-report/analysis"
  eventId       String? // nullable string reference (survives Event deletion)
  costEstimate  Float? // nullable — only for cost-impacting ops
  ip            String? // from x-forwarded-for / x-real-ip
  success       Boolean  @default(true)
  errorMessage  String? // populated on failure
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([route])
  @@index([actor])
  @@map("admin_audit_logs")
}

enum EventStatus {
  UPLOADING
  INGESTING
  READY
  ARCHIVED
}

enum QualityTier {
  AMATEUR
  INTERMEDIATE
  PROFESSIONAL
}

enum AssetType {
  SOURCE_VIDEO
  SOURCE_IMAGE
  CLIP
  PROXY
  FINAL
}

enum AssetStatus {
  UPLOADED
  INGESTING
  SCORED
  FAILED
}

enum ClipType {
  ACTION
  SPEECH
  MIXED
  MONTAGE
}

enum AssetTagSource {
  GIS_AI
  USER_MANUAL
  IMMICH_CLIP
}

enum TargetFormat {
  REEL_15
  REEL_30
  REEL_60
  AD_15
  AD_30
  HIGHLIGHT_60
}

enum EnergyPreset {
  HYPE
  INSPIRATIONAL
  EMOTIONAL
  INSTRUCTIONAL
}

enum CampaignStatus {
  DIRECTING
  SCRIPTED
  PROXY_READY
  APPROVED
  RENDERING
  DONE
  FAILED
}

enum OutputType {
  COLLAGE_POSTER
  HIGHLIGHT_VIDEO_15S
  WRAP_UP_VIDEO
}

enum GenerationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RatingType {
  POSITIVE
  NEGATIVE
}

enum JobType {
  INGEST_CLIP
  SCORE_CLIP
  DIRECT_SCRIPT
  RENDER_PROXY
  RENDER_FINAL
  GENERATE_MUSIC
  FEEDBACK_ANALYSIS
  WEEKLY_CRITIQUE
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  RETRYING
}
