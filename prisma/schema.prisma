// Girls In Sports - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id @default(cuid())
  name        String
  sport       String
  city        String
   eventDate   DateTime
  description String?
  immichAlbumId String? // References Immich album
  thumbnailUrl  String? // Auto-selected best frame from vision ranking
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generatedAssets GeneratedAsset[]
  feedbackRatings FeedbackRating[]

  @@map("events")
}

model GeneratedAsset {
  id           String      @id @default(cuid())
  eventId      String
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  outputType   OutputType
  fileName     String
  filePath     String
  fileSize     Int         @default(0)
  immichAssetId String?    // References Immich asset
  compositionScript String? @db.Text
  costDIEM     Float?
  status       GenerationStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  feedbackRatings FeedbackRating[]
  compositionFeedbacks CompositionFeedback[]

  @@map("generated_assets")
}

model SceneSegment {
  id          String   @id @default(cuid())
  parentId    String   // Immich asset ID of the full video
  eventId     String
  startTime   Float    // seconds from start of parent video
  endTime     Float
  duration    Float
  motionScore Float    // ffmpeg scene detection intensity
  createdAt   DateTime @default(now())

  @@index([parentId])
  @@index([eventId])
  @@map("scene_segments")
}

model CompositionFeedback {
  id                 String   @id @default(cuid())
  compositionId      String
  generatedAsset     GeneratedAsset @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  productionWorthy   Boolean
  ratings            Json?    // { assetSelection, cutTiming, videoLength, transitions, musicFit, musicVolume, aspectRatioHandling, narrativeFlow, textOverlays }

  userIntent         String?  @db.Text
  generatedScript    Json?
  musicPrompt        String?  @db.Text
  musicModel         String?
  selectedAssetIds   String[]
  outputDuration     Float?

  freeformNotes      String?  @db.Text
  likedMost          String?
  wouldChange        String?

  estimatedImpressions Int?
  costDIEM           Float?

  createdAt          DateTime @default(now())

  @@index([compositionId])
  @@index([createdAt])
  @@map("composition_feedbacks")
}

model FeedbackRating {
  id         String        @id @default(cuid())
  eventId    String
  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sourceAssetId String     // Immich asset ID of the source media
  generatedAssetId String?
  generatedAsset GeneratedAsset? @relation(fields: [generatedAssetId], references: [id], onDelete: SetNull)
  rating     RatingType
  createdAt  DateTime      @default(now())

  @@map("feedback_ratings")
}

enum OutputType {
  COLLAGE_POSTER
  HIGHLIGHT_VIDEO_15S
  WRAP_UP_VIDEO
}

enum GenerationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RatingType {
  POSITIVE
  NEGATIVE
}

model AssetQualityFlag {
  id         String   @id @default(cuid())
  assetId    String
  eventId    String
  flags      String[]
  brightness Float?
  fileSize   Int
  duration   Float?
  createdAt  DateTime @default(now())

  @@index([eventId])
  @@index([assetId])
  @@map("asset_quality_flags")
}

model WeeklyCritique {
  id              String   @id @default(cuid())
  weekStart       DateTime // Monday of the week being analyzed
  weekEnd         DateTime // Sunday of the week being analyzed
  totalFeedback   Int      // Number of CompositionFeedback records analyzed
  avgProductionWorthy Float? // Percentage rated as production-worthy

  // Aggregated ratings (average 1-5 per dimension)
  avgRatings      Json?    // { assetSelection, cutTiming, videoLength, transitions, musicFit, musicVolume, aspectRatioHandling, narrativeFlow, textOverlays }

  topIssues       String[] // Most frequently tagged issues (e.g., "Too long", "Wrong music")
  topLiked        String[] // Most common "liked most" freeform themes (extracted by LLM)
  topChanges      String[] // Most common "would change" themes (extracted by LLM)

  // LLM-generated critique text
  critiqueText    String   @db.Text // Full narrative analysis
  actionItems     String[] // Specific, actionable improvements for the pipeline

  modelUsed       String   // Which LLM generated the critique
  costDIEM        Float?

  createdAt       DateTime @default(now())

  @@index([weekStart])
  @@map("weekly_critiques")
}

// ═══════════════════════════════════════════════════════════════════════════════
// US-001: Persistent async job queue
// ═══════════════════════════════════════════════════════════════════════════════

enum JobType {
  INGEST_CLIP
  SCORE_CLIP
  DIRECT_SCRIPT
  RENDER_PROXY
  RENDER_FINAL
  GENERATE_MUSIC
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  RETRYING
}

model Job {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(QUEUED)
  payload     Json?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  retryAfter  DateTime?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  parentJobId String?
  parentJob   Job?      @relation("JobParent", fields: [parentJobId], references: [id])
  childJobs   Job[]     @relation("JobParent")

  @@index([status])
  @@index([status, retryAfter])
  @@index([parentJobId])
  @@map("jobs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// US-014: Lightweight Local Pre-Filter Model
// Phase A: Fast image analysis using sharp + simple heuristics
// Phase B (future): ONNX runtime with a distilled vision model
// ═══════════════════════════════════════════════════════════════════════════════

model PreFilterScore {
  id          String   @id @default(cuid())
  assetId     String   // Immich asset ID
  eventId     String

  // Heuristic scores (0-100, computed locally, no API cost)
  brightnessScore  Int?  // 0 = dark, 100 = well-exposed
  blurScore        Int?  // 0 = blurry, 100 = sharp (Laplacian variance)
  faceScore        Int?  // 0 = no face, 100 = clear face detected
  actionScore      Int?  // 0 = static, 100 = high motion / dynamic
  compositionScore Int?  // 0 = poor framing, 100 = good rule-of-thirds

  // Combined quick-score for sorting before expensive vision API
  overallScore     Int?  // weighted average

  // Whether this passed the pre-filter gate for expensive analysis
  passedFilter Boolean @default(false)

  // Raw feature values for future model training
  featuresJson Json?    // { laplacianVar: float, meanBrightness: float, edgeDensity: float, aspectRatio: float, ... }

  createdAt   DateTime @default(now())

  @@index([assetId])
  @@index([eventId])
  @@index([overallScore])
  @@map("pre_filter_scores")
}
